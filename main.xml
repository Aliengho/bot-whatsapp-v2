<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- FOTO DE PERFIL -->
        <ImageView
            android:id="@+id/imgPerfil"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/perfil"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_bg"
            android:padding="6dp"/>

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 Password Generator AI"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crie senhas fortes e inteligentes"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="25dp"
            android:layout_gravity="center"/>

        <!-- INPUT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="6dp"
            android:layout_marginBottom="10dp">

            <EditText
                android:id="@+id/edtTamanho"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tamanho da senha"
                android:inputType="number"
                android:padding="12dp"/>

            <Button
                android:id="@+id/btnGerar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GERAR SENHA"
                android:layout_marginTop="12dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- RESULTADO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:elevation="6dp">

            <TextView
                android:id="@+id/txtSenha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sua senha aparecerá aqui"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:lineSpacingExtra="6dp"/>
        </LinearLayout>

        <!-- BOTÃO COPIAR -->
        <Button
            android:id="@+id/btnCopiar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COPIAR SENHA"
            android:layout_marginTop="12dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>